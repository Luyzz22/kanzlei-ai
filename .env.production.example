# Produktionsdatenbank (PostgreSQL, z. B. Neon Pooler oder Hetzner)
DATABASE_URL=postgresql://app_user:app_password@db-host:5432/kanzleiai?sslmode=require

# Direkte DB-Verbindung für Prisma CLI (Migrate/Introspection), nicht für Runtime-Pooling
DIRECT_URL=postgresql://app_user:app_password@db-host:5432/kanzleiai?sslmode=require

# Öffentliche URL der Anwendung (z. B. https://kanzlei-ai.de)
NEXTAUTH_URL=https://www.kanzlei-ai.com

# Secret für NextAuth (Token-Signatur/Verschlüsselung)
NEXTAUTH_SECRET=replace-with-generated-secret

# Google OAuth (Anmeldung)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Microsoft OAuth (Anmeldung)
AUTH_MICROSOFT_ID=
AUTH_MICROSOFT_SECRET=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Optional: Azure OpenAI Konfiguration
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
