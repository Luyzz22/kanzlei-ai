generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  ANWALT
  ASSISTENT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  externalId    String?   @unique
  isActive      Boolean   @default(true)
  password      String?
  emailVerified DateTime?
  image         String?
  role          Role      @default(ASSISTENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]

  // Enterprise relations
  memberships       TenantMember[]
  uploadedDocuments Document[] @relation("DocumentUploadedBy")
  documentComments  DocumentComment[]
  documentReviewNotes DocumentReviewNote[] @relation("DocumentReviewNoteAuthor")
  createdFindings DocumentFinding[] @relation("DocumentFindingCreatedBy")
  resolvedFindings DocumentFinding[] @relation("DocumentFindingResolvedBy")
  reviewOwnedDocuments Document[] @relation("DocumentReviewOwner")
  analysisLogs      AnalysisLog[]
  analysisRuns      AnalysisRun[]
  analysisFindingReviews AnalysisFindingReview[]
  auditEvents       AuditEvent[]
  updatedGovernanceSettings TenantGovernanceSettings[] @relation("TenantGovernanceSettingsUpdatedBy")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AnalysisLog {
  id            String   @id @default(cuid())
  tenantId      String?
  userId        String
  documentId    String?
  analysisRunId String?
  modelUsed     String
  tokensUsed    Int
  cost          Float
  duration      Int
  createdAt     DateTime @default(now())

  tenant       Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  document     Document?    @relation(fields: [documentId], references: [id], onDelete: SetNull)
  analysisRun  AnalysisRun? @relation(fields: [analysisRunId], references: [id], onDelete: SetNull)
  auditEvents  AuditEvent[]

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([documentId, createdAt])
  @@index([analysisRunId])
}

// --- Enterprise multi-tenancy & audit logging ---

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      TenantMember[]
  documents    Document[]
  documentComments DocumentComment[]
  documentReviewNotes DocumentReviewNote[]
  documentFindings DocumentFinding[]
  auditEvents  AuditEvent[]
  analysisLogs AnalysisLog[]
  analysisRuns AnalysisRun[]
  analysisFindings AnalysisFinding[]
  documentExtractions DocumentExtraction[]
  analysisFindingReviews AnalysisFindingReview[]
  promptReleases         PromptRelease[]
  governanceSettings TenantGovernanceSettings?
}

model TenantMember {
  id        String     @id @default(cuid())
  tenantId  String
  userId    String
  role      TenantRole @default(MEMBER)
  createdAt DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
}


model TenantGovernanceSettings {
  id                                       String   @id @default(cuid())
  tenantId                                 String   @unique
  sessionTimeoutMinutes                    Int      @default(30)
  requireMfaForPrivilegedRoles             Boolean  @default(true)
  documentRetentionDays                    Int      @default(365)
  autoArchiveApprovedDocuments             Boolean  @default(false)
  adminSessionTimeoutMinutes               Int      @default(30)
  standardSessionTimeoutMinutes            Int      @default(480)
  requireApprovalForPrivilegedRoleChanges  Boolean  @default(true)
  requireReasonForPrivilegedReviewActions  Boolean  @default(true)
  requireFourEyesForApproval              Boolean  @default(true)
  requireReasonForApproval                Boolean  @default(true)
  requireReasonForArchiving               Boolean  @default(true)
  approvalRestrictedToPrivilegedRoles     Boolean  @default(true)
  archivingRestrictedToPrivilegedRoles    Boolean  @default(true)
  reviewStartRestrictedToPrivilegedRoles  Boolean  @default(false)
  defaultDocumentRetentionDays             Int      @default(365)
  auditEvidenceRetentionDays               Int      @default(1825)
  reviewDueDays                            Int      @default(14)
  archiveAfterApprovalDays                 Int      @default(30)
  softDeletePolicyEnabled                  Boolean  @default(false)
  updatedByUserId                          String?
  updatedAt                                DateTime @updatedAt

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedByUser User?  @relation("TenantGovernanceSettingsUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([updatedByUserId])
}

model Document {
  id           String   @id @default(cuid())
  tenantId     String
  uploadedById String?
  title        String   @default("Unbenanntes Dokument")
  documentType String   @default("Sonstiges")
  organizationName String @default("Nicht zugeordnet")
  description  String?
  status       DocumentIntakeStatus @default(EINGEGANGEN)
  filename     String
  mimeType     String?
  sizeBytes    Int?
  sha256       String?  @db.VarChar(64)
  storageKey   String?
  processingStatus DocumentProcessingStatus @default(AUSSTEHEND)
  processedAt   DateTime?
  processingError String?
  extractedTextPreview String?
  textExtractedAt DateTime?
  reviewOwnerId String?
  reviewDueAt DateTime?
  createdAt    DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy   User?         @relation("DocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  reviewOwner  User?         @relation("DocumentReviewOwner", fields: [reviewOwnerId], references: [id], onDelete: SetNull)
  comments     DocumentComment[]
  reviewNotes  DocumentReviewNote[]
  findings            DocumentFinding[]
  analysisLogs        AnalysisLog[]
  analysisRuns        AnalysisRun[]
  aiAnalysisFindings  AnalysisFinding[]
  documentExtractions DocumentExtraction[]
  analysisFindingReviews AnalysisFindingReview[]
  auditEvents  AuditEvent[]

  @@index([tenantId, createdAt])
  @@index([tenantId, reviewDueAt])
  @@index([reviewOwnerId])
}

model DocumentComment {
  id         String   @id @default(cuid())
  tenantId   String
  documentId String
  authorId   String
  body       String   @db.Text
  sectionKey String?  @db.VarChar(64)
  anchorText String?  @db.VarChar(280)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([tenantId, documentId, createdAt])
  @@index([documentId, createdAt])
  @@index([authorId, createdAt])
}

enum DocumentReviewNoteType {
  NOTE
  DECISION_MEMO
}

model DocumentReviewNote {
  id         String   @id @default(cuid())
  tenantId   String
  documentId String
  authorId   String
  type       DocumentReviewNoteType @default(NOTE)
  title      String?  @db.VarChar(160)
  body       String   @db.Text
  sectionKey String?  @db.VarChar(64)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author   User     @relation("DocumentReviewNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([tenantId, documentId, type, createdAt])
  @@index([documentId, createdAt])
  @@index([authorId, createdAt])
}

enum DocumentFindingSeverity {
  NIEDRIG
  MITTEL
  HOCH
}

enum DocumentFindingStatus {
  OFFEN
  GEKLAERT
  AKZEPTIERT
}

model DocumentFinding {
  id           String   @id @default(cuid())
  tenantId     String
  documentId   String
  createdById  String
  title        String   @db.VarChar(180)
  description  String   @db.Text
  severity     DocumentFindingSeverity @default(MITTEL)
  status       DocumentFindingStatus @default(OFFEN)
  sectionKey   String?  @db.VarChar(64)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  resolvedAt   DateTime?
  resolvedById String?

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdBy  User     @relation("DocumentFindingCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  resolvedBy User?    @relation("DocumentFindingResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([tenantId, documentId, status, createdAt])
  @@index([documentId, createdAt])
  @@index([createdById, createdAt])
  @@index([resolvedById, resolvedAt])
}

enum DocumentProcessingStatus {
  AUSSTEHEND
  VERARBEITET
  NICHT_UNTERSTUETZT
  FEHLGESCHLAGEN
}

enum DocumentIntakeStatus {
  EINGEGANGEN
  IN_PRUEFUNG
  FREIGEGEBEN
  ARCHIVIERT
}

model AuditEvent {
  id            String   @id @default(cuid())
  tenantId      String
  actorId       String?
  action        String
  resourceType  String
  resourceId    String?
  documentId    String?
  analysisLogId String?
  ip            String?
  userAgent     String?
  requestId     String?
  prevHash      String?  @db.VarChar(64)
  eventHash     String?  @db.VarChar(64)
  metadata      Json?
  createdAt     DateTime @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor       User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)
  document    Document?    @relation(fields: [documentId], references: [id], onDelete: SetNull)
  analysisLog AnalysisLog? @relation(fields: [analysisLogId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorId, createdAt])
  @@index([resourceType, resourceId])
}

// --- KI-Vertragsanalyse (Multi-Provider, auditierbar) ---

enum AiProviderKind {
  OPENAI
  ANTHROPIC
  GOOGLE_GEMINI
  LLAMA_COMPAT
}

enum AnalysisRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum AnalysisReviewState {
  UNGEPRUEFT
  ENTWURF
  ANALYSIERT
  IN_PRUEFUNG
  FREIGEGEBEN
  ZURUECKGEWIESEN
  WIEDERHOLUNG_ANGEFORDERT
}

enum PromptDefinitionStatus {
  DRAFT
  ACTIVE
  DEPRECATED
}

enum PromptTaskStage {
  EXTRACTION
  RISK_AND_GUIDANCE
}

enum FindingReviewDecision {
  AKZEPTIERT
  ABGELEHNT
  ANGEPASST
}

enum AnalysisPipelineStageName {
  EXTRACTION
  RISK_AND_GUIDANCE
}

model AnalysisRun {
  id                        String                 @id @default(cuid())
  tenantId                  String
  documentId                String
  userId                    String
  status                    AnalysisRunStatus      @default(QUEUED)
  /// Legacy: synchron zu extractionPromptVersion bei neuen Läufen
  promptVersion             String                 @default("1") @db.VarChar(32)
  promptBundleKey           String                 @default("contract_analysis.default") @db.VarChar(120)
  extractionPromptKey       String                 @default("contract.extraction.default") @db.VarChar(120)
  extractionPromptVersion   String                 @default("2025-03-27") @db.VarChar(32)
  riskPromptKey             String                 @default("contract.risk_guidance.default") @db.VarChar(120)
  riskPromptVersion         String                 @default("2025-03-27") @db.VarChar(32)
  runSequence               Int                    @default(1)
  inputTextHash             String?                @db.VarChar(64)
  documentContentHash       String?                @db.VarChar(64)
  startedAt                 DateTime               @default(now())
  completedAt               DateTime?
  primaryProvider           AiProviderKind?
  primaryModel              String?                @db.VarChar(120)
  routerSummary             String?                @db.Text
  fallbackModelKeys         Json?
  structuredOutputValid     Boolean                @default(false)
  validationErrorSummary    String?                @db.Text
  aggregateConfidence       Float?
  riskScore01               Float?
  errorCode                 String?                @db.VarChar(64)
  fallbackReason            String?                @db.Text
  reviewState               AnalysisReviewState    @default(UNGEPRUEFT)
  totalTokensUsed           Int                    @default(0)
  totalCostEstimate         Float                  @default(0)
  durationMs                Int?
  recommendedMeasures       Json?
  negotiationHints          Json?
  explanationSummary        String?                @db.Text

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document  Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  decisions AnalysisProviderDecision[]
  findings  AnalysisFinding[]
  extraction DocumentExtraction?
  findingReviews AnalysisFindingReview[]

  analysisLogs AnalysisLog[]

  @@index([tenantId, documentId, startedAt])
  @@index([tenantId, documentId, runSequence])
  @@index([tenantId, status, startedAt])
  @@index([documentId, startedAt])
}

model AnalysisProviderDecision {
  id                   String          @id @default(cuid())
  analysisRunId        String
  stage                AnalysisPipelineStageName
  attemptOrder         Int
  provider             AiProviderKind
  model                String          @db.VarChar(120)
  selectionReason      String          @db.Text
  wasPrimaryChoice     Boolean         @default(false)
  wasSuccessful        Boolean         @default(false)
  fallbackFromProvider AiProviderKind?
  latencyMs            Int?
  tokensUsed           Int?
  errorCode            String?         @db.VarChar(64)
  structuredValid      Boolean         @default(false)

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)

  @@index([analysisRunId, stage, attemptOrder])
}

model AnalysisFinding {
  id            String   @id @default(cuid())
  tenantId      String
  documentId    String
  analysisRunId String
  category      String   @db.VarChar(64)
  title         String   @db.VarChar(240)
  description   String   @db.Text
  severity      DocumentFindingSeverity
  confidence    Float?
  sourceStage   AnalysisPipelineStageName?
  clauseRef     String?  @db.VarChar(200)
  sourceSpan    String?  @db.Text
  createdAt     DateTime @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document    Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  reviews     AnalysisFindingReview[]

  @@index([tenantId, documentId, createdAt])
  @@index([analysisRunId])
}

/// Mandantenbezogene juristische Bewertung eines KI-Findings (Human-in-the-Loop)
model AnalysisFindingReview {
  id                    String                 @id @default(cuid())
  tenantId              String
  documentId            String
  analysisRunId         String
  analysisFindingId     String
  reviewerId            String
  decision              FindingReviewDecision
  comment               String?                @db.Text
  modifiedTitle         String?                @db.VarChar(240)
  modifiedDescription   String?                @db.Text
  reviewedAt            DateTime               @default(now())

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document    Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  analysisRun AnalysisRun     @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  finding     AnalysisFinding @relation(fields: [analysisFindingId], references: [id], onDelete: Cascade)
  reviewer    User            @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([tenantId, analysisFindingId, reviewedAt])
  @@index([analysisRunId])
  @@index([reviewerId, reviewedAt])
}

/// Globale Prompt-Metadaten (kein Mandantenbezug; Zugriff nur Plattform-Admin)
model PromptDefinition {
  id                   String                 @id @default(cuid())
  key                  String                 @db.VarChar(120)
  version              String                 @db.VarChar(32)
  purpose              String                 @db.Text
  contractTypeScope    Json?
  compatibleProviders  Json?
  status               PromptDefinitionStatus @default(ACTIVE)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  releases PromptRelease[]

  @@unique([key, version])
  @@index([key, status])
}

/// Welche Prompt-Definition für eine Pipeline-Stufe aktiv ist (optional mandantenspezifisch)
model PromptRelease {
  id                 String          @id @default(cuid())
  taskStage          PromptTaskStage
  contractTypePattern String         @default("*") @db.VarChar(120)
  promptDefinitionId String
  tenantId           String?
  active             Boolean         @default(true)
  effectiveFrom      DateTime        @default(now())

  promptDefinition PromptDefinition @relation(fields: [promptDefinitionId], references: [id], onDelete: Cascade)
  tenant           Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([taskStage, active, contractTypePattern])
  @@index([tenantId, taskStage, active])
}

/// Interne Eval-Läufe (kein RLS; nur Admin/CI)
model EvalRun {
  id             String   @id @default(cuid())
  name           String   @db.VarChar(200)
  evaluatorName  String   @default("local") @db.VarChar(64)
  createdAt      DateTime @default(now())
  completedAt    DateTime?
  passed         Boolean  @default(false)
  configSnapshot Json?
  reportJson     Json?
  summaryMarkdown String? @db.Text

  results EvalResultRow[]

  @@index([createdAt])
}

model EvalResultRow {
  id              String   @id @default(cuid())
  evalRunId       String
  caseId          String   @db.VarChar(120)
  providerLabel   String?  @db.VarChar(64)
  modelLabel      String?  @db.VarChar(120)
  promptVersion   String?  @db.VarChar(32)
  metricsJson     Json
  passed          Boolean  @default(false)
  latencyMs       Int?
  costEstimate    Float?

  evalRun EvalRun @relation(fields: [evalRunId], references: [id], onDelete: Cascade)

  @@index([evalRunId, caseId])
}

model DocumentExtraction {
  id             String   @id @default(cuid())
  tenantId       String
  documentId     String
  analysisRunId  String   @unique
  contractType   String   @db.VarChar(120)
  parties        Json
  term           Json
  legalTopics    Json
  confidence     Float?
  promptVersion  String   @db.VarChar(32)
  contentHash    String?  @db.VarChar(64)
  createdAt      DateTime @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document    Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)

  @@index([tenantId, documentId])
}
