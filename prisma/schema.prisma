generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ANWALT
  ASSISTENT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  externalId    String?   @unique
  isActive      Boolean   @default(true)
  password      String?
  emailVerified DateTime?
  image         String?
  role          Role      @default(ASSISTENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]

  // Enterprise relations
  memberships       TenantMember[]
  uploadedDocuments Document[]
  analysisLogs      AnalysisLog[]
  auditEvents       AuditEvent[]
  updatedGovernanceSettings TenantGovernanceSettings[] @relation("TenantGovernanceSettingsUpdatedBy")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AnalysisLog {
  id         String   @id @default(cuid())
  tenantId   String?
  userId     String
  documentId String?
  modelUsed  String
  tokensUsed Int
  cost       Float
  duration   Int
  createdAt  DateTime @default(now())

  tenant      Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  document    Document?    @relation(fields: [documentId], references: [id], onDelete: SetNull)
  auditEvents AuditEvent[]

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([documentId, createdAt])
}

// --- Enterprise multi-tenancy & audit logging ---

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      TenantMember[]
  documents    Document[]
  auditEvents  AuditEvent[]
  analysisLogs AnalysisLog[]
  governanceSettings TenantGovernanceSettings?
}

model TenantMember {
  id        String     @id @default(cuid())
  tenantId  String
  userId    String
  role      TenantRole @default(MEMBER)
  createdAt DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
}


model TenantGovernanceSettings {
  id                            String   @id @default(cuid())
  tenantId                      String   @unique
  sessionTimeoutMinutes         Int      @default(30)
  requireMfaForPrivilegedRoles  Boolean  @default(true)
  documentRetentionDays         Int      @default(365)
  autoArchiveApprovedDocuments  Boolean  @default(false)
  updatedByUserId               String?
  updatedAt                     DateTime @updatedAt

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedByUser User?  @relation("TenantGovernanceSettingsUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([updatedByUserId])
}

model Document {
  id           String   @id @default(cuid())
  tenantId     String
  uploadedById String?
  title        String   @default("Unbenanntes Dokument")
  documentType String   @default("Sonstiges")
  organizationName String @default("Nicht zugeordnet")
  description  String?
  status       DocumentIntakeStatus @default(EINGEGANGEN)
  filename     String
  mimeType     String?
  sizeBytes    Int?
  sha256       String?  @db.VarChar(64)
  storageKey   String?
  processingStatus DocumentProcessingStatus @default(AUSSTEHEND)
  processedAt   DateTime?
  processingError String?
  extractedTextPreview String?
  textExtractedAt DateTime?
  createdAt    DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy   User?         @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  analysisLogs AnalysisLog[]
  auditEvents  AuditEvent[]

  @@index([tenantId, createdAt])
}

enum DocumentProcessingStatus {
  AUSSTEHEND
  VERARBEITET
  NICHT_UNTERSTUETZT
  FEHLGESCHLAGEN
}

enum DocumentIntakeStatus {
  EINGEGANGEN
  IN_PRUEFUNG
  FREIGEGEBEN
  ARCHIVIERT
}

model AuditEvent {
  id            String   @id @default(cuid())
  tenantId      String
  actorId       String?
  action        String
  resourceType  String
  resourceId    String?
  documentId    String?
  analysisLogId String?
  ip            String?
  userAgent     String?
  requestId     String?
  prevHash      String?  @db.VarChar(64)
  eventHash     String?  @db.VarChar(64)
  metadata      Json?
  createdAt     DateTime @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor       User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)
  document    Document?    @relation(fields: [documentId], references: [id], onDelete: SetNull)
  analysisLog AnalysisLog? @relation(fields: [analysisLogId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorId, createdAt])
  @@index([resourceType, resourceId])
}
