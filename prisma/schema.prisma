generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  ANWALT
  ASSISTENT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  externalId    String?   @unique
  isActive      Boolean   @default(true)
  password      String?
  emailVerified DateTime?
  image         String?
  role          Role      @default(ASSISTENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]

  // Enterprise relations
  memberships       TenantMember[]
  uploadedDocuments Document[] @relation("DocumentUploadedBy")
  documentComments  DocumentComment[]
  documentReviewNotes DocumentReviewNote[] @relation("DocumentReviewNoteAuthor")
  createdFindings DocumentFinding[] @relation("DocumentFindingCreatedBy")
  resolvedFindings DocumentFinding[] @relation("DocumentFindingResolvedBy")
  reviewOwnedDocuments Document[] @relation("DocumentReviewOwner")
  analysisLogs      AnalysisLog[]
  analysisRuns      AnalysisRun[]
  analysisFindingReviews AnalysisFindingReview[]
  auditEvents       AuditEvent[]
  updatedGovernanceSettings TenantGovernanceSettings[] @relation("TenantGovernanceSettingsUpdatedBy")
  tokenUsages       TenantTokenUsage[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AnalysisLog {
  id            String   @id @default(cuid())
  tenantId      String?
  userId        String
  documentId    String?
  analysisRunId String?
  modelUsed     String
  tokensUsed    Int
  cost          Float
  duration      Int
  createdAt     DateTime @default(now())

  tenant       Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  document     Document?    @relation(fields: [documentId], references: [id], onDelete: SetNull)
  analysisRun  AnalysisRun? @relation(fields: [analysisRunId], references: [id], onDelete: SetNull)
  auditEvents  AuditEvent[]

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([documentId, createdAt])
  @@index([analysisRunId])
}

// --- Enterprise multi-tenancy & audit logging ---

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      TenantMember[]
  documents    Document[]
  documentComments DocumentComment[]
  documentReviewNotes DocumentReviewNote[]
  documentFindings DocumentFinding[]
  auditEvents  AuditEvent[]
  analysisLogs AnalysisLog[]
  analysisRuns AnalysisRun[]
  analysisFindings AnalysisFinding[]
  documentExtractions DocumentExtraction[]
  analysisFindingReviews AnalysisFindingReview[]
  promptReleases         PromptRelease[]
  governanceSettings TenantGovernanceSettings?
  dynamicsIntegration DynamicsIntegration?
  playbookRules      PlaybookRule[]
  tokenUsages        TenantTokenUsage[]
  normPilotRequirementSets NormPilotRequirementSet[]
  normPilotRequirementItems NormPilotRequirementItem[]
  normPilotEvidenceSources NormPilotEvidenceSource[]
  normPilotEvidenceMappings NormPilotEvidenceMapping[]
  normPilotGapFindings NormPilotGapFinding[]
  normPilotCorrectiveActions NormPilotCorrectiveAction[]
  normPilotEvidencePackExports NormPilotEvidencePackExport[]
}

model TenantMember {
  id        String     @id @default(cuid())
  tenantId  String
  userId    String
  role      TenantRole @default(MEMBER)
  createdAt DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
}


model TenantGovernanceSettings {
  id                                       String   @id @default(cuid())
  tenantId                                 String   @unique
  sessionTimeoutMinutes                    Int      @default(30)
  requireMfaForPrivilegedRoles             Boolean  @default(true)
  documentRetentionDays                    Int      @default(365)
  autoArchiveApprovedDocuments             Boolean  @default(false)
  adminSessionTimeoutMinutes               Int      @default(30)
  standardSessionTimeoutMinutes            Int      @default(480)
  requireApprovalForPrivilegedRoleChanges  Boolean  @default(true)
  requireReasonForPrivilegedReviewActions  Boolean  @default(true)
  requireFourEyesForApproval              Boolean  @default(true)
  requireReasonForApproval                Boolean  @default(true)
  requireReasonForArchiving               Boolean  @default(true)
  approvalRestrictedToPrivilegedRoles     Boolean  @default(true)
  archivingRestrictedToPrivilegedRoles    Boolean  @default(true)
  reviewStartRestrictedToPrivilegedRoles  Boolean  @default(false)
  /// R-02 Fix: Provider-Allowlist pro Tenant (leer = alle erlaubt)
  allowedProviders                        String[]
  /// R-02 Fix: EU-Only-Modus — blockiert US-Provider (OpenAI, Anthropic, Gemini)
  preferEuModels                          Boolean  @default(false)
  /// Phase 1.3: PII-Pseudonymisierung vor LLM-Transfer
  requirePseudonymization                 Boolean  @default(false)
  /// Phase 1.3: Drittlandtransfer explizit freigeben
  allowThirdCountryLlmTransfer            Boolean  @default(false)
  /// Phase 1.3: log_only oder block
  aiPolicyEnforcement                     String   @default("log_only") @db.VarChar(20)
  defaultDocumentRetentionDays             Int      @default(365)
  auditEvidenceRetentionDays               Int      @default(1825)
  reviewDueDays                            Int      @default(14)
  archiveAfterApprovalDays                 Int      @default(30)
  softDeletePolicyEnabled                  Boolean  @default(false)
  updatedByUserId                          String?
  updatedAt                                DateTime @updatedAt

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedByUser User?  @relation("TenantGovernanceSettingsUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([updatedByUserId])
}

model Document {
  id           String   @id @default(cuid())
  tenantId     String
  uploadedById String?
  title        String   @default("Unbenanntes Dokument")
  documentType String   @default("Sonstiges")
  organizationName String @default("Nicht zugeordnet")
  description  String?
  status       DocumentIntakeStatus @default(EINGEGANGEN)
  filename     String
  mimeType     String?
  sizeBytes    Int?
  sha256       String?  @db.VarChar(64)
  storageKey   String?
  processingStatus DocumentProcessingStatus @default(AUSSTEHEND)
  processedAt   DateTime?
  processingError String?
  extractedTextPreview String?
  textExtractedAt DateTime?
  reviewOwnerId String?
  reviewDueAt DateTime?
  createdAt    DateTime @default(now())
  /// R-06 Fix: Soft-Delete Zeitstempel (DSGVO Art. 17)
  deletedAt    DateTime?
  /// R-06 Fix: Automatische Löschung nach Ablauf (DSGVO Art. 5, 25)
  retentionUntil DateTime?

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy   User?         @relation("DocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  reviewOwner  User?         @relation("DocumentReviewOwner", fields: [reviewOwnerId], references: [id], onDelete: SetNull)
  comments     DocumentComment[]
  reviewNotes  DocumentReviewNote[]
  findings            DocumentFinding[]
  analysisLogs        AnalysisLog[]
  analysisRuns        AnalysisRun[]
  aiAnalysisFindings  AnalysisFinding[]
  documentExtractions DocumentExtraction[]
  analysisFindingReviews AnalysisFindingReview[]
  auditEvents  AuditEvent[]
  normPilotRequirementSets NormPilotRequirementSet[]
  normPilotEvidenceSources NormPilotEvidenceSource[]

  @@index([tenantId, createdAt])
  @@index([tenantId, reviewDueAt])
  @@index([reviewOwnerId])
}

model DocumentComment {
  id         String   @id @default(cuid())
  tenantId   String
  documentId String
  authorId   String
  body       String   @db.Text
  sectionKey String?  @db.VarChar(64)
  anchorText String?  @db.VarChar(280)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([tenantId, documentId, createdAt])
  @@index([documentId, createdAt])
  @@index([authorId, createdAt])
}

enum DocumentReviewNoteType {
  NOTE
  DECISION_MEMO
}

model DocumentReviewNote {
  id         String   @id @default(cuid())
  tenantId   String
  documentId String
  authorId   String
  type       DocumentReviewNoteType @default(NOTE)
  title      String?  @db.VarChar(160)
  body       String   @db.Text
  sectionKey String?  @db.VarChar(64)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author   User     @relation("DocumentReviewNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([tenantId, documentId, type, createdAt])
  @@index([documentId, createdAt])
  @@index([authorId, createdAt])
}

enum DocumentFindingSeverity {
  NIEDRIG
  MITTEL
  HOCH
}

enum DocumentFindingStatus {
  OFFEN
  GEKLAERT
  AKZEPTIERT
}

model DocumentFinding {
  id           String   @id @default(cuid())
  tenantId     String
  documentId   String
  createdById  String
  title        String   @db.VarChar(180)
  description  String   @db.Text
  severity     DocumentFindingSeverity @default(MITTEL)
  status       DocumentFindingStatus @default(OFFEN)
  sectionKey   String?  @db.VarChar(64)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  resolvedAt   DateTime?
  resolvedById String?

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdBy  User     @relation("DocumentFindingCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  resolvedBy User?    @relation("DocumentFindingResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([tenantId, documentId, status, createdAt])
  @@index([documentId, createdAt])
  @@index([createdById, createdAt])
  @@index([resolvedById, resolvedAt])
}

enum DocumentProcessingStatus {
  AUSSTEHEND
  VERARBEITET
  NICHT_UNTERSTUETZT
  FEHLGESCHLAGEN
}

enum DocumentIntakeStatus {
  EINGEGANGEN
  IN_PRUEFUNG
  FREIGEGEBEN
  ARCHIVIERT
}

model AuditEvent {
  id            String   @id @default(cuid())
  tenantId      String
  actorId       String?
  action        String
  resourceType  String
  resourceId    String?
  documentId    String?
  analysisLogId String?
  ip            String?
  userAgent     String?
  requestId     String?
  prevHash      String?  @db.VarChar(64)
  eventHash     String?  @db.VarChar(64)
  metadata      Json?
  createdAt     DateTime @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor       User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)
  document    Document?    @relation(fields: [documentId], references: [id], onDelete: SetNull)
  analysisLog AnalysisLog? @relation(fields: [analysisLogId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([actorId, createdAt])
  @@index([resourceType, resourceId])
}

// --- KI-Vertragsanalyse (Multi-Provider, auditierbar) ---

enum AiProviderKind {
  OPENAI
  ANTHROPIC
  GOOGLE_GEMINI
  LLAMA_COMPAT
}

enum AnalysisRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum AnalysisReviewState {
  UNGEPRUEFT
  ENTWURF
  ANALYSIERT
  IN_PRUEFUNG
  FREIGEGEBEN
  ZURUECKGEWIESEN
  WIEDERHOLUNG_ANGEFORDERT
}

enum PromptDefinitionStatus {
  DRAFT
  ACTIVE
  DEPRECATED
}

enum PromptTaskStage {
  EXTRACTION
  RISK_AND_GUIDANCE
}

enum FindingReviewDecision {
  AKZEPTIERT
  ABGELEHNT
  ANGEPASST
  KENNTNISGENOMMEN
}

enum NormPilotReviewState {
  UNGEPRUEFT
  IN_PRUEFUNG
  FREIGEGEBEN
  ZURUECKGEWIESEN
}

enum NormPilotEvidenceStatus {
  COVERED
  PARTIAL
  MISSING
  CONFLICTING
  NOT_APPLICABLE
  NEEDS_REVIEW
}

enum NormPilotGapSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum NormPilotActionStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  DONE
  CANCELLED
}

enum NormPilotEvidencePackExportFormat {
  MARKDOWN
  CSV
  JSON
}

enum NormPilotEvidencePackExportStatus {
  REQUESTED
  GENERATED
  FAILED
}

enum AnalysisPipelineStageName {
  CLASSIFICATION
  EXTRACTION
  RISK_AND_GUIDANCE
}

model AnalysisRun {
  progress         Int             @default(0)
  currentStage     String?
  result           Json?
  error            String?
  retentionUntil   DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  id                        String                 @id @default(cuid())
  tenantId                  String
  documentId                String
  userId                    String
  status                    AnalysisRunStatus      @default(QUEUED)
  /// Legacy: synchron zu extractionPromptVersion bei neuen Läufen
  promptVersion             String                 @default("1") @db.VarChar(32)
  promptBundleKey           String                 @default("contract_analysis.default") @db.VarChar(120)
  extractionPromptKey       String                 @default("contract.extraction.default") @db.VarChar(120)
  extractionPromptVersion   String                 @default("2025-03-27") @db.VarChar(32)
  riskPromptKey             String                 @default("contract.risk_guidance.default") @db.VarChar(120)
  riskPromptVersion         String                 @default("2025-03-27") @db.VarChar(32)
  runSequence               Int                    @default(1)
  inputTextHash             String?                @db.VarChar(64)
  documentContentHash       String?                @db.VarChar(64)
  startedAt                 DateTime               @default(now())
  completedAt               DateTime?
  primaryProvider           AiProviderKind?
  primaryModel              String?                @db.VarChar(120)
  routerSummary             String?                @db.Text
  fallbackModelKeys         Json?
  structuredOutputValid     Boolean                @default(false)
  validationErrorSummary    String?                @db.Text
  aggregateConfidence       Float?
  riskScore01               Float?
  errorCode                 String?                @db.VarChar(64)
  fallbackReason            String?                @db.Text
  reviewState               AnalysisReviewState    @default(UNGEPRUEFT)
  totalTokensUsed           Int                    @default(0)
  totalCostEstimate         Float                  @default(0)
  durationMs                Int?
  recommendedMeasures       Json?
  negotiationHints          Json?
  explanationSummary        String?                @db.Text

  /// v3: Classification Step 0 — vollständiger JSON-Output der Klassifikation
  classificationJson          Json?
  classificationPromptKey     String?                @db.VarChar(120)
  classificationPromptVersion String?                @db.VarChar(32)
  /// Denormalisierte Klassifikations-Felder für Filterung/Analytics
  contractClassification      String?                @db.VarChar(60)
  partyConstellation          String?                @db.VarChar(60)
  agbKontrolleAnwendbar       Boolean?
  /// R-06 Fix: Soft-Delete (DSGVO Art. 17)
  deletedAt                   DateTime?

  /// v5.0 Stage-Chunked Pipeline: persistierter Zwischenstate zwischen Stages.
  /// Enthält {classification, extraction, stageLogs[], fallbackKeys[]} während der
  /// Lauf zwischen Stages pausiert. Wird beim COMPLETE-Übergang konsumiert und
  /// in das finale `result`-Feld + assoziierte Tabellen (findings, decisions)
  /// aggregiert. Nullable, weil Legacy-Sync-Runs (Schnellanalyse) es nicht nutzen.
  stageStateJson              Json?

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document  Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  decisions AnalysisProviderDecision[]
  findings  AnalysisFinding[]
  extraction DocumentExtraction?
  findingReviews AnalysisFindingReview[]

  analysisLogs AnalysisLog[]

  @@index([tenantId, documentId, startedAt])
  @@index([tenantId, documentId, runSequence])
  @@index([tenantId, status, startedAt])
  @@index([tenantId, contractClassification])
  @@index([documentId, startedAt])
}

model AnalysisProviderDecision {
  id                   String          @id @default(cuid())
  analysisRunId        String
  stage                AnalysisPipelineStageName
  attemptOrder         Int
  provider             AiProviderKind
  model                String          @db.VarChar(120)
  selectionReason      String          @db.Text
  wasPrimaryChoice     Boolean         @default(false)
  wasSuccessful        Boolean         @default(false)
  fallbackFromProvider AiProviderKind?
  latencyMs            Int?
  tokensUsed           Int?
  errorCode            String?         @db.VarChar(64)
  structuredValid      Boolean         @default(false)

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)

  @@index([analysisRunId, stage, attemptOrder])
}

model AnalysisFinding {
  id            String   @id @default(cuid())
  tenantId      String
  documentId    String
  analysisRunId String
  category      String   @db.VarChar(64)
  title         String   @db.VarChar(240)
  description   String   @db.Text
  severity      DocumentFindingSeverity
  confidence    Float?
  sourceStage   AnalysisPipelineStageName?
  clauseRef     String?  @db.VarChar(200)
  sourceSpan    String?  @db.Text
  suggestedRevision String? @db.Text
  /// Risk-Nature-Klassifikation (v3): Typ des rechtlichen Risikos
  riskNature    String?  @db.VarChar(80)
  /// Finding-Typ (v3): existing_clause | missing_clause
  findingType   String?  @db.VarChar(30)
  /// Primäre Rechtsgrundlagen (v3): z.B. ["§ 307 BGB"] — denormalisiert für Filter/Analytics
  primaryLegalBasis   String[]
  /// Referenz-/Indiz-Normen (v3): z.B. ["§ 309 Nr. 7 BGB als Wertungsindiz"]
  referenceLegalBasis String[]
  /// Evidence Graph: Structured reasoning chain (normBasis, steps, confidenceFactors)
  evidenceGraph Json?
  createdAt     DateTime @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document    Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  reviews     AnalysisFindingReview[]

  @@index([tenantId, documentId, createdAt])
  @@index([analysisRunId])
}

/// Mandantenbezogene juristische Bewertung eines KI-Findings (Human-in-the-Loop)
model AnalysisFindingReview {
  id                    String                 @id @default(cuid())
  tenantId              String
  documentId            String
  analysisRunId         String
  analysisFindingId     String
  reviewerId            String
  decision              FindingReviewDecision
  comment               String?                @db.Text
  modifiedTitle         String?                @db.VarChar(240)
  modifiedDescription   String?                @db.Text
  modifiedSuggestedRevision String?             @db.Text
  reviewedAt            DateTime               @default(now())

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document    Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  analysisRun AnalysisRun     @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  finding     AnalysisFinding @relation(fields: [analysisFindingId], references: [id], onDelete: Cascade)
  reviewer    User            @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([tenantId, analysisFindingId, reviewedAt])
  @@index([analysisRunId])
  @@index([reviewerId, reviewedAt])
}

// --- NormPilot Industrie: Audit Evidence Sprint Domain Foundation ---

model NormPilotRequirementSet {
  id               String               @id @default(cuid())
  tenantId         String
  title            String               @db.VarChar(240)
  description      String?              @db.Text
  frameworkLabel   String?              @db.VarChar(120)
  scopeLabel       String?              @db.VarChar(200)
  versionLabel     String?              @db.VarChar(80)
  sourceKind       String               @default("customer_checklist") @db.VarChar(80)
  sourceDocumentId String?
  contentHash      String?              @db.VarChar(64)
  reviewState      NormPilotReviewState @default(UNGEPRUEFT)
  metadata         Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  deletedAt        DateTime?
  retentionUntil   DateTime?

  tenant         Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sourceDocument Document?                      @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  items          NormPilotRequirementItem[]
  gapFindings    NormPilotGapFinding[]
  exports        NormPilotEvidencePackExport[]

  @@index([tenantId, createdAt])
  @@index([tenantId, reviewState, createdAt])
  @@index([tenantId, sourceDocumentId])
}

model NormPilotRequirementItem {
  id                String                @id @default(cuid())
  tenantId          String
  requirementSetId  String
  code              String                @db.VarChar(80)
  title             String                @db.VarChar(240)
  customerText      String?               @db.Text
  normReferenceCode String?               @db.VarChar(120)
  sectionLabel      String?               @db.VarChar(160)
  sortOrder         Int                   @default(0)
  criticality       NormPilotGapSeverity?
  reviewState       NormPilotReviewState  @default(UNGEPRUEFT)
  metadata          Json?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  deletedAt         DateTime?
  retentionUntil    DateTime?

  tenant            Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requirementSet    NormPilotRequirementSet        @relation(fields: [requirementSetId], references: [id], onDelete: Cascade)
  mappings          NormPilotEvidenceMapping[]
  gapFindings       NormPilotGapFinding[]
  correctiveActions NormPilotCorrectiveAction[]

  @@unique([tenantId, requirementSetId, code])
  @@index([tenantId, requirementSetId, sortOrder])
  @@index([tenantId, reviewState, createdAt])
}

model NormPilotEvidenceSource {
  id             String               @id @default(cuid())
  tenantId       String
  documentId     String?
  sourceType     String               @db.VarChar(80)
  title          String               @db.VarChar(240)
  sourceHash     String?              @db.VarChar(64)
  locator        Json?
  metadata       Json?
  reviewState    NormPilotReviewState @default(UNGEPRUEFT)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deletedAt      DateTime?
  retentionUntil DateTime?

  tenant   Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document Document?                  @relation(fields: [documentId], references: [id], onDelete: SetNull)
  mappings NormPilotEvidenceMapping[]

  @@index([tenantId, documentId])
  @@index([tenantId, sourceType, createdAt])
  @@index([tenantId, reviewState, createdAt])
}

model NormPilotEvidenceMapping {
  id                String                  @id @default(cuid())
  tenantId          String
  requirementItemId String
  evidenceSourceId  String?
  status            NormPilotEvidenceStatus @default(NEEDS_REVIEW)
  confidence        Float?
  rationale         String?                 @db.Text
  anchorText        String?                 @db.VarChar(280)
  locator           Json?
  evidenceHash      String?                 @db.VarChar(64)
  promptKey         String?                 @db.VarChar(120)
  promptVersion     String?                 @db.VarChar(32)
  provider          String?                 @db.VarChar(40)
  model             String?                 @db.VarChar(120)
  reviewState       NormPilotReviewState    @default(UNGEPRUEFT)
  reviewedAt        DateTime?
  reviewerLabel     String?                 @db.VarChar(120)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  deletedAt         DateTime?
  retentionUntil    DateTime?

  tenant          Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requirementItem NormPilotRequirementItem  @relation(fields: [requirementItemId], references: [id], onDelete: Cascade)
  evidenceSource  NormPilotEvidenceSource?  @relation(fields: [evidenceSourceId], references: [id], onDelete: SetNull)
  gapFindings     NormPilotGapFinding[]

  @@index([tenantId, requirementItemId, status])
  @@index([tenantId, evidenceSourceId])
  @@index([tenantId, reviewState, createdAt])
}

model NormPilotGapFinding {
  id                String               @id @default(cuid())
  tenantId          String
  requirementSetId  String
  requirementItemId String?
  evidenceMappingId String?
  severity          NormPilotGapSeverity @default(MEDIUM)
  title             String               @db.VarChar(240)
  description       String               @db.Text
  recommendation    String?              @db.Text
  sourceSummary     Json?
  confidence        Float?
  promptKey         String?              @db.VarChar(120)
  promptVersion     String?              @db.VarChar(32)
  provider          String?              @db.VarChar(40)
  model             String?              @db.VarChar(120)
  reviewState       NormPilotReviewState @default(UNGEPRUEFT)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  deletedAt         DateTime?
  retentionUntil    DateTime?

  tenant            Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requirementSet    NormPilotRequirementSet   @relation(fields: [requirementSetId], references: [id], onDelete: Cascade)
  requirementItem   NormPilotRequirementItem? @relation(fields: [requirementItemId], references: [id], onDelete: SetNull)
  evidenceMapping   NormPilotEvidenceMapping? @relation(fields: [evidenceMappingId], references: [id], onDelete: SetNull)
  correctiveActions NormPilotCorrectiveAction[]

  @@index([tenantId, requirementSetId, severity])
  @@index([tenantId, requirementItemId])
  @@index([tenantId, reviewState, createdAt])
}

model NormPilotCorrectiveAction {
  id                 String                 @id @default(cuid())
  tenantId           String
  gapFindingId       String?
  requirementItemId  String?
  title              String                 @db.VarChar(240)
  description        String?                @db.Text
  ownerRole          String?                @db.VarChar(120)
  ownerLabel         String?                @db.VarChar(160)
  dueDate            DateTime?
  status             NormPilotActionStatus  @default(DRAFT)
  acceptanceCriteria String?                @db.Text
  reviewState        NormPilotReviewState   @default(UNGEPRUEFT)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  deletedAt          DateTime?
  retentionUntil     DateTime?

  tenant          Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  gapFinding      NormPilotGapFinding?      @relation(fields: [gapFindingId], references: [id], onDelete: SetNull)
  requirementItem NormPilotRequirementItem? @relation(fields: [requirementItemId], references: [id], onDelete: SetNull)

  @@index([tenantId, gapFindingId])
  @@index([tenantId, status, dueDate])
  @@index([tenantId, reviewState, createdAt])
}

model NormPilotEvidencePackExport {
  id               String                            @id @default(cuid())
  tenantId         String
  requirementSetId String
  title            String                            @db.VarChar(240)
  format           NormPilotEvidencePackExportFormat @default(MARKDOWN)
  status           NormPilotEvidencePackExportStatus @default(REQUESTED)
  storageKey       String?
  contentHash      String?                           @db.VarChar(64)
  exportManifest   Json
  promptMetadata   Json?
  reviewSnapshot   Json?
  generatedAt      DateTime?
  createdAt        DateTime                          @default(now())
  updatedAt        DateTime                          @updatedAt
  deletedAt        DateTime?
  retentionUntil   DateTime?

  tenant         Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requirementSet NormPilotRequirementSet @relation(fields: [requirementSetId], references: [id], onDelete: Cascade)

  @@index([tenantId, requirementSetId, createdAt])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, retentionUntil])
}

/// Playbook Miner: persistierte Klausel-Regeln aus Review-Entscheidungen
model PlaybookRule {
  id                String   @id @default(cuid())
  tenantId          String
  category          String   @db.VarChar(120)
  pattern           String   @db.VarChar(40)     // AUTO_ACCEPT, ALWAYS_REJECT, PREFERRED_REVISION, NEEDS_REVIEW, INCONSISTENT
  confidence        Float    @default(0)
  description       String?  @db.Text
  preferredRevision String?  @db.Text
  isActive          Boolean  @default(false)
  samplesCount      Int      @default(0)
  acceptanceRate    Float?
  overrideRate      Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt
  createdBy         String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, category])
  @@index([tenantId, isActive])
}

/// Globale Prompt-Metadaten (kein Mandantenbezug; Zugriff nur Plattform-Admin)
model PromptDefinition {
  id                   String                 @id @default(cuid())
  key                  String                 @db.VarChar(120)
  version              String                 @db.VarChar(32)
  purpose              String                 @db.Text
  contractTypeScope    Json?
  compatibleProviders  Json?
  status               PromptDefinitionStatus @default(ACTIVE)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  releases PromptRelease[]

  @@unique([key, version])
  @@index([key, status])
}

/// Welche Prompt-Definition für eine Pipeline-Stufe aktiv ist (optional mandantenspezifisch)
model PromptRelease {
  id                 String          @id @default(cuid())
  taskStage          PromptTaskStage
  contractTypePattern String         @default("*") @db.VarChar(120)
  promptDefinitionId String
  tenantId           String?
  active             Boolean         @default(true)
  effectiveFrom      DateTime        @default(now())

  promptDefinition PromptDefinition @relation(fields: [promptDefinitionId], references: [id], onDelete: Cascade)
  tenant           Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([taskStage, active, contractTypePattern])
  @@index([tenantId, taskStage, active])
}

/// Interne Eval-Läufe (kein RLS; nur Admin/CI)
model EvalRun {
  id             String   @id @default(cuid())
  name           String   @db.VarChar(200)
  evaluatorName  String   @default("local") @db.VarChar(64)
  createdAt      DateTime @default(now())
  completedAt    DateTime?
  passed         Boolean  @default(false)
  configSnapshot Json?
  reportJson     Json?
  summaryMarkdown String? @db.Text

  results EvalResultRow[]

  @@index([createdAt])
}

model EvalResultRow {
  id              String   @id @default(cuid())
  evalRunId       String
  caseId          String   @db.VarChar(120)
  providerLabel   String?  @db.VarChar(64)
  modelLabel      String?  @db.VarChar(120)
  promptVersion   String?  @db.VarChar(32)
  metricsJson     Json
  passed          Boolean  @default(false)
  latencyMs       Int?
  costEstimate    Float?

  evalRun EvalRun @relation(fields: [evalRunId], references: [id], onDelete: Cascade)

  @@index([evalRunId, caseId])
}

model DocumentExtraction {
  id             String   @id @default(cuid())
  tenantId       String
  documentId     String
  analysisRunId  String   @unique
  contractType   String   @db.VarChar(120)
  parties        Json
  term           Json
  legalTopics    Json
  structuredData Json?
  deadlines      Json?
  confidence     Float?
  promptVersion  String   @db.VarChar(32)
  contentHash    String?  @db.VarChar(64)
  createdAt      DateTime @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document    Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)

  @@index([tenantId, documentId])
}

// =====================================================================
// Microsoft Dynamics 365 Business Central Integration (per-Tenant)
// =====================================================================
// Eine Integration pro Tenant. clientSecretEncrypted enthaelt den via
// AES-256-GCM verschluesselten Client-Secret ("v1:<iv>:<tag>:<ct>").
//
// Entschluesselung: siehe src/lib/dynamics/crypto.ts via
// process.env.DYNAMICS_ENCRYPTION_KEY (32-byte Base64).
// =====================================================================
model DynamicsIntegration {
  id                     String   @id @default(cuid())
  tenantId               String   @unique

  azureTenantId          String   @db.VarChar(64)
  clientId               String   @db.VarChar(64)
  clientSecretEncrypted  String   @db.Text

  environment            String   @default("Production") @db.VarChar(64)
  companyId              String?  @db.VarChar(64)
  companyName            String?  @db.VarChar(200)
  baseUrl                String   @default("https://api.businesscentral.dynamics.com/v2.0") @db.VarChar(300)

  syncEnabled            Boolean  @default(false)
  webhookEnabled         Boolean  @default(false)
  lastSyncAt             DateTime?
  lastSyncStatus         String?  @db.VarChar(32)
  lastSyncError          String?  @db.Text

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  vendors                DynamicsVendor[]
  purchaseOrders         DynamicsPurchaseOrder[]
  purchaseInvoices       DynamicsPurchaseInvoice[]

  @@index([tenantId])
}

// =====================================================================
// Dynamics 365 Business Central — Sync Mirror Tables
// Phase 2: Vendors, Purchase Orders, Purchase Invoices
// =====================================================================

model DynamicsVendor {
  id                String   @id @default(cuid())
  tenantId          String
  bcId              String   @db.VarChar(64)
  number            String   @db.VarChar(32)
  displayName       String   @db.VarChar(300)
  addressLine1      String?  @db.VarChar(300)
  city              String?  @db.VarChar(100)
  country           String?  @db.VarChar(100)
  phoneNumber       String?  @db.VarChar(64)
  email             String?  @db.VarChar(200)
  balance           Decimal? @db.Decimal(18, 2)
  currencyCode      String?  @db.VarChar(10)
  lastModifiedAt    DateTime?
  syncedAt          DateTime @default(now())

  /// Matching: verknuepfter KanzleiAI-Organisationsname (aus Vertragsanalyse)
  matchedOrgName    String?  @db.VarChar(300)
  matchConfidence   Float?

  integration       DynamicsIntegration @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)

  @@unique([tenantId, bcId])
  @@index([tenantId, displayName])
  @@index([tenantId, number])
}

model DynamicsPurchaseOrder {
  id                String   @id @default(cuid())
  tenantId          String
  bcId              String   @db.VarChar(64)
  number            String   @db.VarChar(32)
  orderDate         DateTime?
  vendorId          String?  @db.VarChar(64)
  vendorNumber      String?  @db.VarChar(32)
  vendorName        String?  @db.VarChar(300)
  status            String?  @db.VarChar(32)
  totalAmount       Decimal? @db.Decimal(18, 2)
  currencyCode      String?  @db.VarChar(10)
  lastModifiedAt    DateTime?
  syncedAt          DateTime @default(now())

  integration       DynamicsIntegration @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)

  @@unique([tenantId, bcId])
  @@index([tenantId, vendorId])
  @@index([tenantId, orderDate])
}

model DynamicsPurchaseInvoice {
  id                String   @id @default(cuid())
  tenantId          String
  bcId              String   @db.VarChar(64)
  number            String   @db.VarChar(32)
  invoiceDate       DateTime?
  dueDate           DateTime?
  vendorId          String?  @db.VarChar(64)
  vendorNumber      String?  @db.VarChar(32)
  vendorName        String?  @db.VarChar(300)
  status            String?  @db.VarChar(32)
  totalAmount       Decimal? @db.Decimal(18, 2)
  remainingAmount   Decimal? @db.Decimal(18, 2)
  currencyCode      String?  @db.VarChar(10)
  lastModifiedAt    DateTime?
  syncedAt          DateTime @default(now())

  integration       DynamicsIntegration @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade)

  @@unique([tenantId, bcId])
  @@index([tenantId, vendorId])
  @@index([tenantId, invoiceDate])
}

model TenantTokenUsage {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source       String   @db.VarChar(30)
  provider     String   @db.VarChar(30)
  inputTokens  Int
  outputTokens Int
  costCentsUsd Int      @default(0)
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, source])
  @@index([tenantId, userId, createdAt])
}
