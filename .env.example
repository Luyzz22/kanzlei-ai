DATABASE_URL=postgresql://user:password@localhost:5432/kanzleiai
DIRECT_URL=postgresql://user:password@localhost:5432/kanzleiai
NEXTAUTH_SECRET=your-secret-here-min-32-chars
NEXTAUTH_URL=http://localhost:3001
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# AI Model Configuration (alle optional — ohne Key wird der Anbieter übersprungen)
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIzaSy...
OPENAI_API_KEY=sk-proj...

# Optional: OpenAI-kompatibler Endpunkt (z. B. Llama, EU-Hosting)
LLAMA_API_KEY=
LLAMA_API_BASE=
LLAMA_MODEL=

# API-Modell-IDs — WICHTIG: datierte Snapshots für reproduzierbare Output-Limits
# Alias (claude-sonnet-4-5) kann sich still ändern und andere max_tokens-Limits haben.
# Empfohlen Production (wenn 4.6 auf dem Konto verfügbar): claude-sonnet-4-6-20260217
# Sonnet 4.5 Snapshot (häufig verfügbar): claude-sonnet-4-5-20250929
OPENAI_CHAT_MODEL=gpt-4o
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-5-20250929
GEMINI_CHAT_MODEL=gemini-2.5-pro

# Anthropic: Alias → Snapshot-Mapping (Default true). false = ENV-Wert 1:1 an API
AI_ANTHROPIC_PIN_ALIASES=true

# Vertragsanalyse: nur Claude Sonnet, kein stilles Fallback auf OpenAI/Gemini (Default true).
# Für lokale Dev ohne Anthropic: AI_CONTRACT_ANALYSIS_CLAUDE_ONLY=false
AI_CONTRACT_ANALYSIS_CLAUDE_ONLY=true

# Risk-Stage ab dieser Dokumentlänge in 2 Phasen (Findings + Guidance)
AI_RISK_SPLIT_CHAR_THRESHOLD=25000

# v5 Async Worker (Stage-Chunked Pipeline)
WORKER_TOKEN=

# Model Selection Strategy (Legacy + Router-Hinweise)
DEFAULT_MODEL=claude-sonnet-4
LONG_DOCUMENT_MODEL=gemini-2.5-pro
SIMPLE_QUERY_MODEL=gpt-4o-mini
MAX_TOKENS_GEMINI=1000000
MAX_TOKENS_CLAUDE=200000

# Multi-Modell-Router / Pipeline
AI_ROUTER_ENABLED=true
AI_PROVIDER_PRIORITY=openai,anthropic,gemini,llama
AI_LONG_DOCUMENT_CHAR_THRESHOLD=50000
AI_MAX_INPUT_CHARS=120000
AI_SENSITIVE_USE_LLAMA=false
AI_AUDIT_VERBOSE=false
AUTH_MICROSOFT_ID=
AUTH_MICROSOFT_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=
AUTH_MICROSOFT_ALLOWED_TENANT_IDS=
AUTH_MICROSOFT_ADMIN_ROLES=
# SCIM nur setzen, wenn Provisioning aktiv genutzt wird
SCIM_BEARER_TOKEN=
SCIM_TENANT_SLUG=
SCIM_GROUP_ADMIN=KanzleiAI.Admin
SCIM_GROUP_ANWALT=KanzleiAI.Anwalt
SCIM_GROUP_ASSISTENT=KanzleiAI.Assistent
SCIM_BEARER_TOKENS=
SCIM_ALLOWED_IPS=
