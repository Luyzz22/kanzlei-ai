# ═══════════════════════════════════════════════════════════════
# KanzleiAI — Environment Variables
# Nur Platzhalter, KEINE echten Werte committen!
# ═══════════════════════════════════════════════════════════════

# ── Datenbank ──
DATABASE_URL=postgresql://user:password@localhost:5432/kanzleiai
DIRECT_URL=postgresql://user:password@localhost:5432/kanzleiai

# ── Auth ──
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3001
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_MICROSOFT_ID=
AUTH_MICROSOFT_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=
AUTH_MICROSOFT_ALLOWED_TENANT_IDS=
AUTH_MICROSOFT_ADMIN_ROLES=

# ── KI-Provider (alle optional — ohne Key wird der Anbieter übersprungen) ──
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional: OpenAI-kompatibler Endpunkt (z.B. Llama, EU-Hosting)
LLAMA_API_KEY=
LLAMA_API_BASE=
LLAMA_MODEL=

# ── Modell-IDs (optional, sinnvolle Defaults im Code) ──
OPENAI_CHAT_MODEL=gpt-4o-mini
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-20250514
GEMINI_CHAT_MODEL=gemini-2.5-pro

# ── Router / Pipeline ──
DEFAULT_MODEL=claude-sonnet-4
LONG_DOCUMENT_MODEL=gemini-2.5-pro
SIMPLE_QUERY_MODEL=gpt-4o-mini
AI_ROUTER_ENABLED=true
AI_PROVIDER_PRIORITY=anthropic,gemini,openai,llama
AI_LONG_DOCUMENT_CHAR_THRESHOLD=50000
AI_MAX_INPUT_CHARS=120000
AI_SENSITIVE_USE_LLAMA=false
AI_AUDIT_VERBOSE=false

# ── SCIM Provisioning (nur aktivieren wenn benötigt) ──
SCIM_BEARER_TOKEN=
SCIM_TENANT_SLUG=
SCIM_BEARER_TOKENS=
SCIM_ALLOWED_IPS=
