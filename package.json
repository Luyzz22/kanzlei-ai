{
  "name": "kanzlei-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://user:password@localhost:5432/kanzleiai} DIRECT_URL=${DIRECT_URL:-${DATABASE_URL:-postgresql://user:password@localhost:5432/kanzleiai}} prisma generate",
    "prisma:migrate": "DIRECT_URL=${DIRECT_URL:-$DATABASE_URL} prisma migrate dev",
    "prisma:validate": "DATABASE_URL=${DATABASE_URL:-postgresql://user:password@localhost:5432/kanzleiai} DIRECT_URL=${DIRECT_URL:-${DATABASE_URL:-postgresql://user:password@localhost:5432/kanzleiai}} prisma validate",
    "typecheck": "tsc --noEmit",
    "eval:contracts": "EVAL_MOCK=true tsx --tsconfig tsconfig.json scripts/run-contract-evals.ts",
    "eval:contracts:persist": "EVAL_MOCK=true EVAL_PERSIST_DB=1 tsx --tsconfig tsconfig.json scripts/run-contract-evals.ts -- --persist",
    "test": "tsx --test src/lib/ai/__tests__/*.test.ts src/lib/documents/__tests__/*.test.ts src/lib/evals/__tests__/contract-eval-runner.test.ts src/lib/evals/__tests__/eval-model-matrix.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@auth/core": "0.41.1",
    "@auth/prisma-adapter": "2.11.1",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-slot": "^1.1.1",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "14.2.26",
    "next-auth": "5.0.0-beta.25",
    "next-themes": "^0.4.4",
    "openai": "^6.25.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.26",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "unrs-resolver"
    ]
  }
}
